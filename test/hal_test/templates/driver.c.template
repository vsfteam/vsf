// VSF标准输出字符函数实现（参考AIC8800方式）
VSF_CAL_ROOT int vsf_stdout_putchar(char ch)
{
    {{DEVICE_LOWER}}_uart_putc(ch);
    return (int)ch;
}

// VSF标准输入字符函数实现（参考AIC8800方式）
VSF_CAL_ROOT int vsf_stdin_getchar(void)
{
    if ({{DEVICE_LOWER}}_uart_tstc()) {
        return (int){{DEVICE_LOWER}}_uart_getc();
    }
    return -1; // 没有字符可读
}

